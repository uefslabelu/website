---
import ContentLayout from "../../layouts/ContentLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const roleOrder = [
  { label: "Coordenador", weight: 0 },
  { label: "Coordenadora", weight: 0 },
  { label: "Vice-Coordenador", weight: 1 },
  { label: "Vice-Coordenadora", weight: 1 },
  { label: "Pesquisador", weight: 2 },
  { label: "Pesquisadora", weight: 2 },
  { label: "Analista", weight: 3 },
  { label: "Estagiário", weight: 4 },
  { label: "Estagiária", weight: 4 },
];

const team = (await getCollection("team"))
  .map((e) => ({
    slug: e.id,
    fullname: e.data.fullname,
    role: e.data.role ?? "",
    summary: e.body,
    lattes: e.data.lattes,
    orcid: e.data.orcid ?? "",
    linkedin: e.data.linkedin ?? "",
    profile: e.data.profile ?? null,
  }))
  .sort((a, b) => {
    const rolePrecedence =
      (roleOrder.find((r) => r.label === a.role)?.weight ?? 99) -
      (roleOrder.find((r) => r.label === b.role)?.weight ?? 99);

    return rolePrecedence !== 0
      ? rolePrecedence
      : a.fullname.localeCompare(b.fullname);
  });
const baseUrl = import.meta.env.BASE_URL;
---

<ContentLayout
  title="Equipe"
  description="Conheça nossa equipe de pesquisadores dedicados à história e memória da luta de classes"
>
  <ul class="divide-y divide-border pb-24" role="list">
    {
      team.map((p, i) => (
        <li
          class="group relative flex gap-8 py-10 items-start max-sm:flex-col
                  before:content-[''] before:absolute before:-left-6 before:inset-y-0
                  before:w-0.5 before:bg-accent-600 before:scale-y-0 before:origin-top
                  before:transition-transform before:duration-300
                  hover:before:scale-y-100 auto-show"
        >
          <a
            href={`${baseUrl}equipe/${p.slug}`}
            class="absolute inset-0 z-0"
            aria-label={`Ir para perfil de ${p.fullname}`}
          />
          <span
            class="pointer-events-none absolute right-0 top-8 font-heading font-bold
                  leading-none select-none text-8xl text-raised
                  transition-colors duration-300 group-hover:text-accent-50
                  max-sm:hidden z-5"
            aria-hidden="true"
          >
            {String(i + 1).padStart(2, "0")}
          </span>

          <div
            class="auto-colorize shrink-0 w-28 overflow-hidden bg-raised max-sm:w-full max-sm:h-36 relative z-10 cursor-pointer pointer-events-none"
            style="aspect-ratio: 3/4;"
            transition:name={`profile-image-${p.slug}`}
          >
            {p.profile ? (
              <Image
                src={p.profile}
                alt={`Foto de ${p.fullname}`}
                class="w-full h-full object-cover transition-all duration-300 group-hover:grayscale-0"
                widths={[160, 240, 320, 480]}
                sizes="(max-width: 639px) 100vw, 7rem"
              />
            ) : (
              <img
                src={`https://api.dicebear.com/9.x/lorelei-neutral/svg?backgroundColor=ffd5dc,ffffff,ffdfbf&backgroundType=solid,gradientLinear&backgroundRotation=0,360,-50,-30,-110,50&randomizeIds=true&seed=${p.fullname}`}
                class="w-full h-full object-cover transition-all duration-300 group-hover:grayscale-0"
                alt="avatar"
              />
            )}
          </div>

          <div class="flex-1 min-w-0 pr-24 flex flex-col gap-3 max-sm:pr-0 relative z-10 pointer-events-none">
            <div class="cursor-pointer">
              <h2
                class="font-heading text-2xl font-semibold text-title leading-tight"
                transition:name={`profile-name-${p.slug}`}
              >
                {p.fullname}
              </h2>
              <p
                class="mt-1 text-xs uppercase tracking-widest text-secondary-text font-medium"
                transition:name={`profile-role-${p.slug}`}
              >
                {p.role}
              </p>
            </div>

            <p
              class="text-sm text-body leading-relaxed line-clamp-3"
              transition:name={`profile-summary-${p.slug}`}
            >
              {p.summary}
            </p>

            <div class="flex items-center gap-6 pt-1 relative z-10 pointer-events-auto">
              <a
                href={p.lattes}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs font-semibold text-accent-600 hover:text-accent-800 transition-colors duration-150"
                transition:name={`profile-lattes-${p.slug}`}
              >
                Currículo Lattes ↗
              </a>
              <a
                href="#"
                class="hidden text-xs font-semibold uppercase tracking-widest text-secondary-text
                      border-b border-border pb-px
                      hover:text-accent-600 hover:border-accent-600 transition-colors duration-150"
              >
                Ver Produções
              </a>
            </div>
          </div>
        </li>
      ))
    }
  </ul>
</ContentLayout>
