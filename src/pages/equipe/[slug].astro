---
import Layout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const team = await getCollection("team");
  return team.map((member) => ({
    params: { slug: member.id },
    props: { member },
  }));
}

interface Props {
  member: any;
}

const { member } = Astro.props;

const { fullname, role, lattes, orcid, linkedin, profile } = member.data;
const body = member.body;

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title={fullname} description={role}>
  <article class="max-w-4xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 py-8">
      {/* Profile Image */}
      <div class="md:col-span-1 flex justify-center">
        <div
          class="w-full max-w-xs overflow-hidden bg-raised"
          style="aspect-ratio: 3/4;"
        >
          {
            profile ? (
              <Image
                src={profile}
                alt={`Foto de ${fullname}`}
                class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-300"
              />
            ) : (
              <img
                src={`https://api.dicebear.com/9.x/lorelei-neutral/svg?backgroundColor=ffd5dc,ffffff,ffdfbf&backgroundType=solid,gradientLinear&backgroundRotation=0,360,-50,-30,-110,50&randomizeIds=true&seed=${fullname}`}
                class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-300"
                alt="avatar"
              />
            )
          }
        </div>
      </div>

      {/* Content */}
      <div class="md:col-span-2 flex flex-col gap-8">
        {/* Header */}
        <div class="border-b border-border pb-8">
          <h1
            class="font-heading text-4xl font-semibold text-title leading-tight mb-2"
          >
            {fullname}
          </h1>
          <p
            class="text-sm uppercase tracking-widest text-secondary-text font-medium"
          >
            {role}
          </p>
          <a
            href={`${baseUrl}/equipe/`}
            class="text-sm text-accent-600 font-semibold no-underline hover:underline"
          >
            ← Voltar para a equipe
          </a>
        </div>

        {/* Links */}
        <div class="flex flex-wrap gap-4">
          {
            lattes && (
              <a
                href={lattes}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center px-4 py-2 rounded border border-accent-600 text-accent-600 hover:bg-accent-600 hover:text-raised transition-colors duration-150 font-semibold text-sm"
              >
                Currículo Lattes ↗
              </a>
            )
          }
          {
            orcid && (
              <a
                href={orcid}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center px-4 py-2 rounded border border-border text-secondary-text hover:border-accent-600 hover:text-accent-600 transition-colors duration-150 font-semibold text-sm"
              >
                ORCID ↗
              </a>
            )
          }
          {
            linkedin && (
              <a
                href={linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center px-4 py-2 rounded border border-border text-secondary-text hover:border-accent-600 hover:text-accent-600 transition-colors duration-150 font-semibold text-sm"
              >
                LinkedIn ↗
              </a>
            )
          }
        </div>

        {/* Body Content */}
        <div class="prose prose-invert max-w-none text-body leading-relaxed">
          <Fragment set:html={body} />
        </div>
      </div>
    </div>
  </article>
</Layout>
