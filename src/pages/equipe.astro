---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const team = (await getCollection("team")).map((e) => ({
  fullname: e.data.fullname,
  role: e.data.role ?? "",
  summary: e.data.summary,
  lattes: e.data.lattes,
  orcid: e.data.orcid ?? "",
  linkedin: e.data.linkedin ?? "",
  profile: e.data.profile ?? null,
}));
---

<BaseLayout title={`Equipe — ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <div class="bg-page min-h-screen">
    <div class="max-w-4xl mx-auto px-6">
      <header class="pt-16 pb-10">
        <p
          class="text-xs tracking-[0.2em] uppercase text-secondary-text font-medium mb-4"
        >
          {SITE_TITLE}
        </p>
        <h1
          class="font-heading text-8xl font-bold text-title leading-none tracking-tight mb-8"
        >
          Equipe
        </h1>
        <div class="h-px bg-border"></div>
      </header>

      <ul class="divide-y divide-border pb-24" role="list">
        {
          team.map((p, i) => (
            <li
              class="group relative flex gap-8 py-10 items-start max-sm:flex-col
                     before:content-[''] before:absolute before:-left-6 before:inset-y-0
                     before:w-0.5 before:bg-accent-600 before:scale-y-0 before:origin-top
                     before:transition-transform before:duration-300
                     hover:before:scale-y-100"
            >
              <span
                class="pointer-events-none absolute right-0 top-8 font-heading font-bold
                     leading-none select-none text-8xl text-raised
                     transition-colors duration-300 group-hover:text-accent-50
                     max-sm:hidden"
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, "0")}
              </span>

              <div
                class="shrink-0 w-28 overflow-hidden bg-raised max-sm:w-full max-sm:h-36"
                style="aspect-ratio: 3/4;"
              >
                {p.profile ? (
                  <Image
                    src={p.profile}
                    alt={`Foto de ${p.fullname}`}
                    class="w-full h-full object-cover grayscale transition-all duration-300 group-hover:grayscale-0"
                  />
                ) : (
                  <div class="w-full h-full grayscale transition-all duration-300 group-hover:grayscale-0">
                    <svg
                      viewBox="0 0 112 150"
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-full h-full block"
                    >
                      <rect
                        width="112"
                        height="150"
                        fill="var(--color-raised)"
                      />
                      <ellipse
                        cx="56"
                        cy="54"
                        rx="22"
                        ry="24"
                        fill="var(--color-border)"
                      />
                      <ellipse
                        cx="56"
                        cy="126"
                        rx="44"
                        ry="36"
                        fill="var(--color-border)"
                      />
                    </svg>
                  </div>
                )}
              </div>

              <div class="flex-1 min-w-0 pr-24 flex flex-col gap-3 max-sm:pr-0">
                <div>
                  <h2 class="font-heading text-2xl font-semibold text-title leading-tight">
                    {p.fullname}
                  </h2>
                  <p class="mt-1 text-xs uppercase tracking-widest text-secondary-text font-medium">
                    {p.role}
                  </p>
                </div>

                <p class="text-sm text-body leading-relaxed line-clamp-3">
                  {p.summary}
                </p>

                <div class="flex items-center gap-6 pt-1">
                  <a
                    href={p.lattes}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-xs font-semibold text-accent-600 hover:text-accent-800 transition-colors duration-150"
                  >
                    Currículo Lattes ↗
                  </a>
                  <a
                    href="#"
                    class="text-xs font-semibold uppercase tracking-widest text-secondary-text
                         border-b border-border pb-px
                         hover:text-accent-600 hover:border-accent-600 transition-colors duration-150"
                  >
                    Ver Produções
                  </a>
                </div>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</BaseLayout>
