---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

// Buscar pesquisadores da collection
const entries = await getCollection('pesquisadores');
const pesquisadores = entries.map((e) => ({
  name: e.data.name,
  position: e.data.position ?? '',
  academicLevel: e.data.academicLevel,
  summary: e.data.summary,
  lattes: e.data.lattes,
  orcid: e.data.orcid ?? '',
  linkedin: e.data.linkedin ?? '',
  image: e.data.image ?? null,
}));
---

<BaseLayout title={`Equipe — ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <div class="equipe-wrapper">
    <div class="equipe-container">

      <h1 class="equipe-titulo">EQUIPE</h1>

      <ul class="pesquisadores-list" role="list">
        {pesquisadores.map((p) => (
          <li class="card">

            <!-- Foto -->
            <div class="card-foto">
              {p.image ? (
                <Image src={p.image} alt={`Foto de ${p.name}`} class="foto-img" />
              ) : (
                <div class="foto-fallback" aria-hidden="true">
                  <svg viewBox="0 0 130 160" xmlns="http://www.w3.org/2000/svg" width="130" height="160">
                    <rect width="130" height="160" fill="#d4d4d4"/>
                    <ellipse cx="65" cy="58" rx="26" ry="28" fill="#a3a3a3"/>
                    <ellipse cx="65" cy="136" rx="50" ry="40" fill="#a3a3a3"/>
                  </svg>
                </div>
              )}
            </div>

            <!-- Conteúdo -->
            <div class="card-content">

              <div class="card-header">
                <h2 class="pesquisador-nome">{p.name}</h2>
                {p.position && <p class="pesquisador-cargo">{p.position}</p>}
                <p class="pesquisador-grau">{p.academicLevel}</p>
              </div>

              <p class="pesquisador-resumo">{p.summary}</p>

              <div class="card-actions">
                <a href="#" class="btn-pesquisas">Ver Produções</a>
              </div>

            </div>
          </li>
        ))}
      </ul>

    </div>
  </div>
</BaseLayout>

<style>
  :global(main) {
    width: 100% !important;
    max-width: 100% !important;
    padding: 0 !important;
  }

  .equipe-wrapper {
    background-color: #efefef;
    min-height: 100vh;
    padding: 3rem 1.5rem 5rem;
  }

  .equipe-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .equipe-titulo {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--accent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 2rem 0;
    line-height: 1;
  }

  .pesquisadores-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .card {
    background: #ffffff;
    border-radius: 2px;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    overflow: hidden;
  }

  .card-foto {
    flex-shrink: 0;
    width: 130px;
    background-color: #d4d4d4;
  }

  .foto-img {
    width: 130px;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
  }

  .foto-fallback {
    width: 130px;
    height: 100%;
    display: block;
  }

  .foto-fallback svg {
    display: block;
    width: 130px;
    height: 100%;
  }

  .card-content {
    flex: 1;
    min-width: 0;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .card-header {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .pesquisador-nome {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0;
    line-height: 1.3;
  }

  .pesquisador-cargo {
    font-size: 0.75rem;
    color: rgb(var(--gray-dark));
    margin: 0;
    line-height: 1.4;
  }

  .pesquisador-grau {
    font-size: 0.7rem;
    color: rgb(var(--gray));
    margin: 0;
    line-height: 1.4;
  }

  .pesquisador-resumo {
    font-size: 0.75rem;
    color: rgb(var(--gray-dark));
    line-height: 1.6;
    margin: 0.1rem 0 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.4rem;
    flex-wrap: wrap;
  }

  .link-ver-mais {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: rgb(var(--gray));
    text-decoration: none;
    transition: color 0.15s;
  }

  .link-ver-mais:hover {
    color: var(--accent);
  }

  .btn-produções {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: rgb(var(--gray-dark));
    border: 1.5px solid rgb(var(--gray-dark));
    padding: 0.28rem 0.7rem;
    border-radius: 2px;
    text-decoration: none;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .btn-produções:hover {
    background-color: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  @media (max-width: 560px) {
    .card {
      flex-direction: column;
    }

    .card-foto {
      width: 100%;
      height: 140px;
    }

    .foto-img {
      width: 100%;
      height: 140px;
    }

    .foto-fallback,
    .foto-fallback svg {
      width: 100%;
      height: 140px;
    }
  }
</style>