---
import { CONTACT_EMAIL, LOCATION } from "../../consts";
import ContentLayout from "../../layouts/ContentLayout.astro";
import { getCollection } from "astro:content";

import Section from "./_Section.astro";
import Hr from "./_Hr.astro";

const grupos = await getCollection("archive");

const dadosFixos = {
  horarios: "Segunda a Sexta, das 08h às 12h e das 14h às 18h",
};
---

<ContentLayout
  title="Acesso ao Acervo Físico"
  description="Instruções, horários de funcionamento e formulário de solicitação formal para acessar o acervo físico do Laboratório de História e Memória da Luta de Classes."
>
  <article class="flex flex-col gap-6">
    <Section id="instruções" title="Instruções para o Pedido Formal">
      <p>
        Para solicitar o acesso ao acervo físico do laboratório, preencha o
        formulário abaixo detalhando os objetivos da sua pesquisa e quais grupos
        de documentos você pretende consultar.
        <br />
        Nossa equipe analisará o pedido e responderá via e-mail.
      </p>
    </Section>

    <Section id="endereço" title="Contato e Funcionamento">
      <ul class="list-none p-0 m-0 flex flex-col gap-3">
        <li><strong>Localização:</strong> {LOCATION}</li>
        <li><strong>Horários:</strong> {dadosFixos.horarios}</li>
        <li><strong>E-mail:</strong> {CONTACT_EMAIL}</li>
      </ul>
    </Section>

    <Hr/>

    <Section id="acervos-disponiveis" title="Acervos disponíveis para consulta">
      <ul class="flex flex-col gap-10">
        {
          grupos.map((grupo) => (
            <li>
              <h3 class="text-xl font-bold text-accent-600 mb-2">
                {grupo.data.title}
              </h3>
              <p class="mb-4">{grupo.body}</p>
            </li>
          ))
        }
      </ul>
    </Section>

    <Hr/>

    <form
      id="solicitacao-de-acesso"
      aria-label="Formulário de Solicitação de Acesso ao Acervo"
      class="flex flex-col gap-6"
    >
      <h2 class="text-2xl font-bold text-accent-600">Solicitação de Acesso</h2>
      <p>
        Preencha os dados abaixo. Ao clicar em enviar, seu aplicativo de e-mail
        será aberto com o pedido formatado.
      </p>

      <section class="flex flex-col gap-2">
        <label for="nome" class="font-semibold">Nome Completo</label>
        <input
          type="text"
          id="nome"
          name="nome"
          required
          class="px-3 py-3 border border-border rounded-md bg-white
              focus:outline-none focus:ring-2 focus:ring-accent-500
              focus:border-accent-500 transition-shadow duration-150
              placeholder:text-secondary-text"
          placeholder="Digite seu nome completo"
        />
      </section>

      <section class="flex flex-col gap-2">
        <label for="email-usuario" class="font-semibold">Seu E-mail</label>
        <input
          type="email"
          id="email-usuario"
          name="email-usuario"
          required
          class="px-3 py-3 border border-border rounded-md bg-white
              focus:outline-none focus:ring-2 focus:ring-accent-500
              focus:border-accent-500 transition-shadow duration-150
              placeholder:text-secondary-text"
          placeholder="seu.email@exemplo.com"
        />
      </section>

      <section class="flex flex-col gap-2">
        <label for="motivo" class="font-semibold">
          Motivo do Interesse / Pesquisa
        </label>
        <textarea
          id="motivo"
          name="motivo"
          rows="5"
          required
          class="px-3 py-3 border border-border rounded-md bg-white
              focus:outline-none focus:ring-2 focus:ring-accent-500
              focus:border-accent-500 transition-shadow duration-150
              placeholder:text-secondary-text resize-y"
          placeholder="Explique brevemente sua pesquisa e quais documentos deseja consultar..."
        ></textarea>
      </section>

      <button
        type="submit"
        class="bg-accent-600 text-white rounded-lg px-6 py-3 font-bold
            cursor-pointer w-max transition-colors duration-200
            hover:bg-accent-800 border-none max-[720px]:w-full"
        data-destino={CONTACT_EMAIL}
      >
        Abrir no e-mail
      </button>
    </form>
  </article>
</ContentLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById(
      "solicitacao-de-acesso",
    ) as HTMLFormElement;

    if (form) {
      form.addEventListener("submit", (e) => {
        e.preventDefault();

        const nome = (document.getElementById("nome") as HTMLInputElement)
          .value;
        const emailUsuario = (
          document.getElementById("email-usuario") as HTMLInputElement
        ).value;
        const motivo = (
          document.getElementById("motivo") as HTMLTextAreaElement
        ).value;

        const btn = form.querySelector("[data-destino]") as HTMLButtonElement;
        const emailDestino = btn.getAttribute("data-destino");

        const subject = encodeURIComponent(
          `Solicitação de Acesso ao Acervo - ${nome}`,
        );
        const body = encodeURIComponent(
          `Nome: ${nome}\nE-mail de Contato: ${emailUsuario}\n\nMotivo da solicitação e documentos de interesse:\n${motivo}`,
        );

        window.open(
          `mailto:${emailDestino}?subject=${subject}&body=${body}`,
          "_blank",
        );
      });
    }
  });
</script>
