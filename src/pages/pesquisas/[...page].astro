---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

import ContentLayout from "../../layouts/ContentLayout.astro";
import PesquisaCard from "../../components/PesquisaCard.astro";
import Paginate from "../../components/Paginate.astro";

type Research = CollectionEntry<"research">;

export const getStaticPaths = (async ({ paginate }) => {
  const PAGE_SIZE = 10;

  const pesquisas = (await getCollection("research")).sort(
    (a, b) => (b.data.endYear ?? 0) - (a.data.endYear ?? 0),
  );

  return paginate(pesquisas, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<Research>;
}

const { page } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<ContentLayout
  title="Pesquisas"
  description="Conheça as pesquisas desenvolvidas pelo Laboratório de História e Memória da Luta de Classes"
>
  <nav class="mb-8" aria-label="Navegação de pesquisas">
    <a
      href={`${baseUrl}/pesquisas/linhas`}
      class="text-sm font-semibold text-accent-600 no-underline
             transition-colors duration-150 hover:text-accent-800 hover:underline"
    >
      Ver linhas de pesquisa →
    </a>
  </nav>

  <ul class="space-y-4" role="list">
    {
      page.data.map((pesquisa) => (
        <li>
          <PesquisaCard pesquisa={pesquisa} />
        </li>
      ))
    }
  </ul>
  <Paginate page={page} />
</ContentLayout>
