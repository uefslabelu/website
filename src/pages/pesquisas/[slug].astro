---
import {
  type CollectionEntry,
  getCollection,
  getEntry,
  render,
} from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export const getStaticPaths = async () =>
  (await getCollection("research")).map((pesquisa) => ({
    params: { slug: pesquisa.id },
    props: pesquisa,
  }));

type Props = CollectionEntry<"research">;

const pesquisa = Astro.props;
const { title, line, startYear, endYear, summary, publication, researchers } =
  pesquisa.data;
const { Content } = await render(pesquisa);

const currentYear = new Date().getFullYear();

// Determine if we have dates and status
const hasStartYear = startYear !== null && startYear !== undefined;
const hasEndYear = endYear !== null && endYear !== undefined;
const hasBothYears = hasStartYear && hasEndYear;
const isOngoing = hasBothYears ? endYear >= currentYear : hasStartYear;

const baseUrl = import.meta.env.BASE_URL;

// Resolve research line to get full title
const researchLineEntry = await getEntry("researchLine", line);
const researchLineTitle = researchLineEntry?.data.title || line;

// Format date display
let dateDisplay = "";
if (hasStartYear) {
  if (hasEndYear) {
    dateDisplay = `${startYear} – ${endYear}`;
  } else {
    dateDisplay = `${startYear} – ${currentYear}`;
  }
}

// Resolve researcher IDs to full team member data
const resolvedResearchers = (
  await Promise.all(researchers.map((id) => getEntry("team", id)))
).filter(Boolean);

// JSON-LD structured data
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  name: title,
  description: summary,
  dateCreated: `${startYear}`,
  ...(publication && { url: publication }),
  author: resolvedResearchers.map((r) => ({
    "@type": "Person",
    name: r.data.fullname,
    ...(r.data.lattes && { url: r.data.lattes }),
  })),
};
---

<BaseLayout title={`${title} — Pesquisas — Labelu`} description={summary}>
  <article class="max-w-180 mx-auto px-4 py-8">
    <nav class="mb-8" aria-label="Navegação estrutural">
      <a
        href={`${baseUrl}pesquisas/`}
        class="text-sm font-semibold text-accent-600 no-underline
               transition-colors duration-150 hover:text-accent-800 hover:underline"
      >
        ← Voltar para Pesquisas
      </a>
    </nav>

    <header class="mb-6">
      <div
        class="flex justify-between items-center flex-wrap gap-2 mb-4
                  max-[720px]:flex-col max-[720px]:items-start"
      >
        {
          dateDisplay && (
            <span class="text-sm text-secondary-text font-bold">
              {dateDisplay}
            </span>
          )
        }

        <div class="flex gap-1.5 flex-wrap">
          {
            hasStartYear &&
              (isOngoing ? (
                <span class="text-[0.7rem] uppercase tracking-wider px-2.5 py-0.5 rounded-full font-semibold whitespace-nowrap bg-accent-500 text-white">
                  Em andamento
                </span>
              ) : (
                <span class="text-[0.7rem] uppercase tracking-wider px-2.5 py-0.5 rounded-full font-semibold whitespace-nowrap bg-accent-800 text-white">
                  Finalizada
                </span>
              ))
          }
          <span
            class="text-[0.7rem] uppercase tracking-wider px-2.5 py-0.5
                       rounded-full font-semibold whitespace-nowrap
                       bg-raised text-body"
          >
            {researchLineTitle}
          </span>
        </div>
      </div>

      <h1 class="text-4xl mb-3 max-[720px]:text-3xl">{title}</h1>
      <p class="text-lg text-secondary-text mb-3">{summary}</p>

      {/* Pesquisadores */}
      {
        resolvedResearchers.length > 0 && (
          <div class="flex items-center gap-2 text-sm text-secondary-text flex-wrap mb-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="shrink-0 opacity-60"
              aria-hidden="true"
            >
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
              <circle cx="9" cy="7" r="4" />
              <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
              <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
            {resolvedResearchers.map((r, i) => (
              <>
                <a
                  href={r.data.lattes}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent-600 no-underline hover:underline font-medium"
                  title={`Currículo Lattes de ${r.data.fullname}`}
                >
                  {r.data.fullname}
                </a>
                {i < resolvedResearchers.length - 1 && (
                  <span class="text-border" aria-hidden="true">
                    ·
                  </span>
                )}
              </>
            ))}
          </div>
        )
      }

      {/* Publicação */}
      {
        publication && (
          <a
            href={publication}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-semibold
                   text-accent-600 no-underline hover:underline"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="shrink-0"
              aria-hidden="true"
            >
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="16" y1="13" x2="8" y2="13" />
              <line x1="16" y1="17" x2="8" y2="17" />
              <polyline points="10 9 9 9 8 9" />
            </svg>
            Ver publicação ↗
          </a>
        )
      }
    </header>

    <hr class="border-none border-t-2 border-border my-6" />

    <div class="prose prose-stone max-w-none">
      <Content />
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
