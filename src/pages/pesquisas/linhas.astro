---
import ContentLayout from "../../layouts/ContentLayout.astro";
import { getCollection, render } from "astro:content";

const baseUrl = import.meta.env.BASE_URL;

const lines = await getCollection("pesquisas");
const orderedLines = await Promise.all(
  lines.sort((a, b) => (a.data.order || 0) - (b.data.order || 0)),
);
---

<ContentLayout
  title="Linhas de Pesquisa"
  description="Conheça as linhas de pesquisa do Labelu"
>
  {
    orderedLines.map((line, index) => (
      <>
        {index > 0 && <hr class="border-border my-12" />}
        <article>
          <h2
            id={line.id}
            class="font-heading text-2xl font-bold text-accent-600 mb-6"
          >
            Linha {line.data.order} — {line.data.title}
          </h2>
          <div class="text-base text-body leading-relaxed mb-8 prose prose-sm max-w-none">
            {line.body}
          </div>
          <a href={`${baseUrl}/pesquisas`} class="underline text-accent-500">
            Retornar
          </a>
        </article>
      </>
    ))
  }
</ContentLayout>
