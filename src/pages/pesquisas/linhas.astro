---
import ContentLayout from "../../layouts/ContentLayout.astro";
import { getCollection, render } from "astro:content";

const baseUrl = import.meta.env.BASE_URL;

const lines = await getCollection("researchLine");
const orderedLines = await Promise.all(
  lines.sort((a, b) => (a.data.order || 0) - (b.data.order || 0)),
);
---

<ContentLayout
  title="Linhas de Pesquisa"
  description="Conheça as linhas de pesquisa do Labelu"
>
  <ul class="divide-y divide-border pb-24" role="list">
    {
      orderedLines.map((line, index) => (
        <li
          class="group relative flex gap-8 py-10 items-start
                  before:content-[''] before:absolute before:-left-6 before:inset-y-0
                  before:w-0.5 before:bg-accent-600 before:scale-y-0 before:origin-top
                  before:transition-transform before:duration-300
                  hover:before:scale-y-100"
        >
          <span
            class="pointer-events-none absolute right-0 top-8 font-heading font-bold
                  leading-none select-none text-8xl text-raised
                  transition-colors duration-300 group-hover:text-accent-50"
            aria-hidden="true"
          >
            {String(index + 1).padStart(2, "0")}
          </span>

          <article class="flex-1 min-w-0 pr-24">
            <h2
              id={line.id}
              class="font-heading text-2xl font-bold text-accent-600 mb-6"
            >
              {line.data.title}
            </h2>
            <div class="text-base text-body leading-relaxed mb-8 prose prose-sm max-w-none">
              {line.body}
            </div>
            <a href="/pesquisas/" class="underline text-accent-500">
              Retornar
            </a>
          </article>
        </li>
      ))
    }
  </ul>
</ContentLayout>
