---
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const configUrl = `${baseUrl}admin/config.yml`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <link href={configUrl} type="text/yaml" rel="cms-config-url" />
    <title>Content Manager</title>

    <link rel="manifest" href="/pj-labelu/admin/manifest.webmanifest" />
    <meta name="theme-color" content="#5c1208" />
  </head>
  <body>
    <script>
      import CMS from "@sveltia/cms";

      CMS.init();
    </script>
  </body>
</html>

<script>
  if ("serviceWorker" in navigator) {
    navigator.serviceWorker.register("/pj-labelu/admin/sw.js", {
      scope: "/pj-labelu/admin/",
    });
  }
</script>
