---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

import ContentLayout from "../../layouts/ContentLayout.astro";
import TimelineEvent from "../../components/TimelineEvent.astro";

import { sortBy } from "../../lib/vec";
import { groupBy } from "../../lib/dict";
import { titled } from "../../lib/text";

type Schedule = CollectionEntry<"schedule">;

export const getStaticPaths = (async ({ paginate }) => {
  const PAGE_SIZE = 20;
  const schedule = sortBy(await getCollection("schedule"), "data");
  return paginate(schedule, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<Schedule>;
}

const { page } = Astro.props;

type MonthsEvents = { label: string; eventos: Schedule[] }[];

function eventsByMonth(events: Schedule[]): MonthsEvents {
  const months = groupBy(events, (event) =>
    titled(
      event.data.date.toLocaleDateString("pt-BR", {
        month: "long",
        year: "numeric",
      }),
    ),
  );
  return Object.entries(months).map(([label, eventos]) => ({ label, eventos }));
}

const months = eventsByMonth(page.data);
---

<ContentLayout
  title="Agenda"
  description="Agenda de eventos do Laboratório de História e Memória da Luta de Classes"
>
  {
    months.map((month) => (
      <div class="mb-4">
        <h2
          class="text-sm font-bold uppercase tracking-[0.08em] text-accent-800
                  pb-2 mb-2 border-b-2 border-accent-600 inline-block"
        >
          {month.label}
        </h2>
        <ol class="timeline list-none p-0 mt-4 mb-8 relative" role="list">
          {month.eventos.map((event) => (
            <TimelineEvent event={event} />
          ))}
        </ol>
      </div>
    ))
  }

  <!-- Pagination -->
  {
    (page.url.prev || page.url.next) && (
      <nav
        class="flex justify-between items-center py-6 border-t border-border
              mt-4 max-[720px]:flex-col max-[720px]:gap-3"
        aria-label="Paginação da agenda"
      >
        {page.url.prev ? (
          <a
            href={page.url.prev}
            class="text-sm font-semibold px-4 py-2 rounded-lg no-underline
                  text-accent-600 bg-raised transition-colors duration-150
                  hover:bg-border hover:text-accent-800"
          >
            ← Mais recentes
          </a>
        ) : (
          <span class="text-sm font-semibold px-4 py-2 text-secondary-text opacity-40 cursor-default">
            ← Mais recentes
          </span>
        )}

        <span class="text-sm font-semibold text-secondary-text">
          Página {page.currentPage} de {page.lastPage}
        </span>

        {page.url.next ? (
          <a
            href={page.url.next}
            class="text-sm font-semibold px-4 py-2 rounded-lg no-underline
                  text-accent-600 bg-raised transition-colors duration-150
                  hover:bg-border hover:text-accent-800"
          >
            Mais antigos →
          </a>
        ) : (
          <span class="text-sm font-semibold px-4 py-2 text-secondary-text opacity-40 cursor-default">
            Mais antigos →
          </span>
        )}
      </nav>
    )
  }
</BaseLayout>

<style>
  .timeline::before {
    content: "";
    position: absolute;
    left: 1rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: var(--color-border);
  }

  @media (max-width: 720px) {
    .timeline::before {
      left: 0.75rem;
    }
  }
</style>
