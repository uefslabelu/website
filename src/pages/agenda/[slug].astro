---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const eventos = await getCollection('agenda');
	return eventos.map((evento) => ({
		params: { slug: evento.id },
		props: evento,
	}));
}

type Props = CollectionEntry<'agenda'>;

const evento = Astro.props;
const { title: titulo, category: categoria, agenda: pauta, date: data, time: hora, local } = evento.data;
const { Content } = await render(evento);

const now = new Date();
const realizado = data.valueOf() < now.valueOf();

const dataFormatada = data.toLocaleDateString('pt-BR', {
	weekday: 'long',
	day: '2-digit',
	month: 'long',
	year: 'numeric',
});

const baseUrl = import.meta.env.BASE_URL;

// JSON-LD structured data for the event
const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'Event',
	name: titulo,
	description: pauta,
	startDate: hora ? `${data.toISOString().split('T')[0]}T${hora}:00` : data.toISOString().split('T')[0],
	eventStatus: realizado
		? 'https://schema.org/EventScheduled'
		: 'https://schema.org/EventScheduled',
	...(local && {
		location: {
			'@type': 'Place',
			name: local,
		},
	}),
};
---

<BaseLayout title={`${titulo} — Agenda — Labelu`} description={pauta}>
	<article class="evento-page">
		{/* Breadcrumb */}
		<nav class="breadcrumb" aria-label="Navegação estrutural">
			<a href={`${baseUrl}agenda/`}>← Voltar para a Agenda</a>
		</nav>

		<header class="evento-header">
			<div class="evento-meta">
				<time datetime={data.toISOString().split('T')[0]}>
					{dataFormatada}
					{hora && <span class="evento-hora"> · {hora}</span>}
				</time>
				<div class="evento-badges">
					{realizado && <span class="badge badge-realizado">Realizado</span>}
					<span class="badge badge-categoria">{categoria}</span>
				</div>
			</div>

			<h1>{titulo}</h1>
			<p class="evento-pauta">{pauta}</p>

			{local && (
				<p class="evento-local">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
					{local}
				</p>
			)}
		</header>

		<hr class="evento-divider" />

		<div class="prose evento-body">
			<Content />
		</div>
	</article>

	{/* JSON-LD structured data */}
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>

<style>
	.evento-page {
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	/* ── Breadcrumb ── */
	.breadcrumb {
		margin-bottom: 2rem;
	}

	.breadcrumb a {
		font-size: 0.9rem;
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
		transition: color 0.15s ease;
	}

	.breadcrumb a:hover {
		color: var(--accent-dark);
		text-decoration: underline;
	}

	/* ── Header ── */
	.evento-header {
		margin-bottom: 1.5rem;
	}

	.evento-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}

	.evento-meta time {
		font-size: 0.9rem;
		color: rgb(var(--gray));
		font-weight: 700;
	}

	.evento-hora {
		font-weight: 400;
	}

	.evento-badges {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
	}

	.badge {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 0.2rem 0.6rem;
		border-radius: 999px;
		font-weight: 600;
		white-space: nowrap;
	}

	.badge-categoria {
		background: rgba(var(--gray-light), 60%);
		color: rgb(var(--gray-dark));
	}

	.badge-realizado {
		background: var(--accent-dark);
		color: #fff;
	}

	.evento-header h1 {
		font-size: 2.2rem;
		line-height: 1.2;
		margin-bottom: 0.75rem;
	}

	.evento-pauta {
		font-size: 1.1rem;
		color: rgb(var(--gray));
		line-height: 1.6;
		margin-bottom: 0.75rem;
	}

	.evento-local {
		font-size: 0.95rem;
		color: rgb(var(--gray));
		display: flex;
		align-items: center;
		gap: 0.4rem;
	}

	.evento-local svg {
		flex-shrink: 0;
		opacity: 0.6;
	}

	/* ── Divider ── */
	.evento-divider {
		border: none;
		border-top: 2px solid rgb(var(--gray-light));
		margin: 1.5rem 0 2rem;
	}

	/* ── Body ── */
	.evento-body {
		color: rgb(var(--gray-dark));
	}

	.evento-body :global(h2) {
		font-size: 1.5rem;
		margin-top: 2rem;
	}

	.evento-body :global(h3) {
		font-size: 1.25rem;
		margin-top: 1.5rem;
	}

	.evento-body :global(ul),
	.evento-body :global(ol) {
		padding-left: 1.5rem;
	}

	.evento-body :global(li) {
		margin-bottom: 0.5rem;
	}

	.evento-body :global(a) {
		color: var(--accent);
		text-decoration: underline;
	}

	.evento-body :global(a:hover) {
		color: var(--accent-dark);
	}

	/* Embedded content (iframes, videos) */
	.evento-body :global(iframe) {
		width: 100%;
		max-width: 100%;
		aspect-ratio: 16 / 9;
		border-radius: 8px;
		border: none;
		margin: 1rem 0;
	}

	/* ── Mobile ── */
	@media (max-width: 720px) {
		.evento-header h1 {
			font-size: 1.6rem;
		}

		.evento-meta {
			flex-direction: column;
			align-items: flex-start;
		}

		.evento-pauta {
			font-size: 1rem;
		}
	}
</style>
