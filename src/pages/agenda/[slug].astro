---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export const getStaticPaths = async () =>
  (await getCollection("schedule")).map((evento) => ({
    params: { slug: evento.id },
    props: evento,
  }));

type Props = CollectionEntry<"schedule">;

const event = Astro.props;
const { title, category, agenda, date, time, local } = event.data;
const { Content } = await render(event);

const now = new Date();
const hasFinished = date.valueOf() < now.valueOf();

const localizedDate = date.toLocaleDateString("pt-BR", {
  weekday: "long",
  day: "2-digit",
  month: "long",
  year: "numeric",
});

const baseUrl = import.meta.env.BASE_URL;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: title,
  description: agenda,
  startDate: time
    ? `${date.toISOString().split("T")[0]}T${time}:00`
    : date.toISOString().split("T")[0],
  eventStatus: "https://schema.org/EventScheduled",
  ...(local && { location: { "@type": "Place", name: local } }),
};
---

<BaseLayout title={`${title} — Agenda — Labelu`} description={agenda}>
  <article class="max-w-180 mx-auto px-4 py-8">
    <nav class="mb-8" aria-label="Navegação estrutural">
      <button
        onclick="history.back()"
        class="cursor text-sm font-semibold text-accent-600 no-underline
               transition-colors duration-150 hover:text-accent-800 hover:underline"
      >
        ← Voltar para a Agenda
      </button>
    </nav>
    <header class="mb-6">
      <div
        class="flex justify-between items-center flex-wrap gap-2 mb-4
                  max-[720px]:flex-col max-[720px]:items-start"
      >
        <time
          datetime={date.toISOString().split("T")[0]}
          class="text-sm text-secondary-text font-bold"
          transition:name={`time-${event.id}`}
        >
          {localizedDate}
          {time && <span class="font-normal"> · {time}</span>}
        </time>

        <div class="flex gap-1.5 flex-wrap">
          {
            hasFinished && (
              <span
                transition:name={`finished-${event.id}`}
                class="text-[0.7rem] uppercase tracking-wider px-2.5 py-0.5
                         rounded-full font-semibold whitespace-nowrap
                         bg-accent-800 text-white"
              >
                Realizado
              </span>
            )
          }
          <span
            transition:name={`category-${event.id}`}
            class="text-[0.7rem] uppercase tracking-wider px-2.5 py-0.5
                       rounded-full font-semibold whitespace-nowrap
                       bg-raised text-body"
          >
            {category}
          </span>
        </div>
      </div>

      <!-- h1 font/color/tracking/leading all from @layer base -->
      <h1 class="text-4xl mb-3 max-[720px]:text-3xl" transition:name={`title-${event.id}`}>
        {title}
      </h1>

      <!-- agenda summary — leading comes from @layer base p -->
      <p class="text-lg text-secondary-text mb-3" transition:name={`description-${event.id}`}>
        {agenda}
      </p>

      {
        local && (
          <p
            transition:name={`location-${event.id}`}
            class="text-sm text-secondary-text flex items-center gap-1.5">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="shrink-0 opacity-60"
              aria-hidden="true"
            >
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            {local}
          </p>
        )
      }
    </header>
    <hr class="border-none border-t-2 border-border my-6" />
    <div class="prose prose-stone max-w-none evento-body text-justify">
      <Content />
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
