---
import { COPYRIGHT_NAME } from '../consts';
import { Image } from 'astro:assets';
import logoLabelu from '../assets/logo-labelu.svg';
import logoUefs from '../assets/logo-uefs.svg';
import logoEcompjr from '../assets/logo-ecompjr.png';

const year = new Date().getFullYear();
---

<footer>
	<div class="footer-content">
		<!-- Associação Institucional com a UEFS -->
		<div class="footer-section">
			<Image src={logoUefs} alt="Logo UEFS" width={64} height={64} />
			<p>Associado à Universidade Estadual de Feira de Santana</p>
		</div>

		<!-- Nome do Laboratório e logo -->
		<div class="footer-section">
			<Image src={logoLabelu} alt="Logo Labelu" width={120} height={36} />
			<p>Laboratório de História e Memória da Luta de Classes</p>
		</div>

		<!-- Redes Sociais -->
		<div class="footer-section">
			<p class="section-title">Redes Sociais</p>
			<div class="social-links">
				<a href="https://instagram.com/labelu.uefs" target="_blank" rel="noopener" aria-label="Instagram do Labelu">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24">
						<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
						<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
						<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
					</svg>
				</a>
				<a href="https://youtube.com/@labelu" target="_blank" rel="noopener" aria-label="Youtube do Labelu">
					<svg viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
						<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
					</svg>
				</a>
			</div>
		</div>
	</div>

	<!-- Créditos e Copyright -->
	<div class="footer-bottom">
		<p>
			Desenvolvido por
			<a href="https://ecompjr.com.br" target="_blank" rel="noopener">
				<Image src={logoEcompjr} alt="Logo EcompJR" width={20} height={20} class="ecompjr-logo" />
				EcompJR
			</a>
		</p>
		<p>&copy; {year} {COPYRIGHT_NAME}. Todos os direitos reservados.</p>
	</div>
</footer>

<style>
	footer {
		background: rgb(var(--gray-dark));
		color: rgba(255, 255, 255, 0.8);
		padding: 2.5rem 1.5rem 1.5rem;
		margin-top: auto;
	}
	.footer-content {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		align-items: center;
		gap: 2rem;
		max-width: 900px;
		margin: 0 auto 2rem;
	}
	.footer-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		gap: 0.6rem;
	}
	.footer-section img {
		border-radius: 4px;
	}
	.footer-section p {
		margin: 0;
		font-size: 0.8rem;
		line-height: 1.5;
		max-width: 220px;
	}
	.section-title {
		font-weight: 700;
		color: #fff;
		font-size: 0.85rem !important;
		margin-bottom: 0.25rem;
	}
	.social-links {
		display: flex;
		gap: 1.25rem;
		justify-content: center;
		align-items: center;
	}
	.social-links a {
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		display: flex;
		align-items: center;
		transition: color 0.2s ease, transform 0.2s ease;
	}
	.social-links a:hover {
		color: #fff;
		transform: scale(1.1);
	}
	.social-links svg {
		width: 28px;
		height: 28px;
	}
	.footer-bottom {
		border-top: 1px solid rgba(255, 255, 255, 0.15);
		max-width: 900px;
		margin: 0 auto;
		padding-top: 1.25rem;
		text-align: center;
	}
	.footer-bottom p {
		margin: 0 0 0.25rem;
		font-size: 0.78rem;
		color: rgba(255, 255, 255, 0.5);
	}
	.footer-bottom a {
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
	}
	.footer-bottom a:hover {
		color: #fff;
	}
	.footer-bottom :global(.ecompjr-logo) {
		border-radius: 2px;
		vertical-align: middle;
	}

	@media (max-width: 768px) {
		.footer-content {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
