---
import { COPYRIGHT_NAME } from '../consts';
import { Image } from 'astro:assets';
import logoLabelu from '../assets/logo-labelu.png';
import logoUefs from '../assets/logo-uefs.svg';
import logoEcompjr from '../assets/logo-ecompjr.svg';
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();
---

<footer>
	<div class="footer-content">
		<!-- Associação Institucional com a UEFS -->
		<div class="footer-section">
			<Image src={logoUefs} alt="Logo UEFS" width={64} height={64} class="invert-colors" />
			<p>Associado à Universidade Estadual de Feira de Santana</p>
		</div>

		<!-- Nome do Laboratório e logo -->
		<div class="footer-section">
			<Image src={logoLabelu} alt="Logo Labelu" width={120} height={64} />
			<p>Laboratório de História e Memória da Luta de Classes</p>
		</div>

		<!-- Redes Sociais -->
		<div class="footer-section">
			<p class="section-title">Redes Sociais</p>
			<div class="social-links">
				<a href="https://www.instagram.com/uefslabelu/" target="_blank" rel="noopener" aria-label="Instagram do Labelu">
					<Icon name="mdi:instagram" size={28} />
				</a>
				<a href="https://www.youtube.com/@LABELUuefs" target="_blank" rel="noopener" aria-label="Youtube do Labelu">
					<Icon name="mdi:youtube" size={28} />
				</a>
			</div>
		</div>
	</div>

	<!-- Créditos e Copyright -->
	<div class="footer-bottom">
		<p class="developed-by">
			Desenvolvido por
			<a href="https://ecompjr.com.br" target="_blank" rel="noopener">
				<Image src={logoEcompjr} alt="Logo EcompJR" width={100} height={100} class="ecompjr-logo" />
			</a>
		</p>
		<p>&copy; {year} {COPYRIGHT_NAME}. Todos os direitos reservados.</p>
	</div>
</footer>

<style>
	footer {
		background: rgb(var(--gray-dark));
		color: rgba(255, 255, 255, 0.8);
		padding: 2.5rem 1.5rem 1.5rem;
		margin-top: auto;
	}
	.footer-content {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		align-items: center;
		gap: 2rem;
		max-width: 900px;
		margin: 0 auto 2rem;
	}
	.footer-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		gap: 0.6rem;
	}
	.footer-section img {
		border-radius: 4px;
	}
	.footer-section p {
		margin: 0;
		font-size: 0.8rem;
		line-height: 1.5;
		max-width: 220px;
	}
	.section-title {
		font-weight: 700;
		color: #fff;
		font-size: 0.85rem !important;
		margin-bottom: 0.25rem;
	}
	.social-links {
		display: flex;
		gap: 1.25rem;
		justify-content: center;
		align-items: center;
	}
	.social-links a {
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		display: flex;
		align-items: center;
		transition: color 0.2s ease, transform 0.2s ease;
	}
	.social-links a:hover {
		color: #fff;
		transform: scale(1.1);
	}
	.social-links svg {
		width: 28px;
		height: 28px;
	}
	.footer-section :global(.invert-colors) {
		filter: invert(1);
	}
	.footer-bottom {
		border-top: 1px solid rgba(255, 255, 255, 0.15);
		max-width: 900px;
		margin: 0 auto;
		padding-top: 1.25rem;
		text-align: center;
	}
	.footer-bottom p {
		margin: 0 0 0.25rem;
		font-size: 0.78rem;
		color: rgba(255, 255, 255, 0.5);
	}
	.footer-bottom .developed-by {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}
	.footer-bottom a {
		color: rgba(255, 255, 255, 0.7);
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
	}
	.footer-bottom a:hover {
		color: #fff;
	}
	.footer-bottom :global(.ecompjr-logo) {
		border-radius: 2px;
		vertical-align: middle;
	}

	@media (max-width: 768px) {
		.footer-content {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
