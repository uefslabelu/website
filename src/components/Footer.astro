---
import { COPYRIGHT_NAME } from "../consts";
import { Image } from "astro:assets";
import logoLabelu from "../assets/logo-labelu.png";
import logoUefs from "../assets/logo-uefs.svg";
import logoEcompjr from "../assets/logo-ecompjr.svg";
import { Icon } from "astro-icon/components";

const year = new Date().getFullYear();
---

<footer class="mt-12 bg-accent-600 py-8 text-white">
  <main
    class="container mx-auto grid grid-cols-1 px-6 md:grid-cols-2 md:items-start"
  >
    <section class="flex flex-col items-center gap-4 text-center">
      <a
        href="https://ppgh.uefs.br/grupos-e-nucleos/"
        target="_blank"
        rel="noopener"
        aria-label="Grupos e Núcleos de Pesquisa da UEFS"
        class="flex flex-1 flex-col items-center text-white no-underline transition-opacity hover:opacity-90"
      >
        <div class="flex h-20 items-center justify-center">
          <Image
            src={logoUefs}
            width={64}
            height={64}
            class="invert object-center"
            alt="Logo da Universidade Estadual de Feira de Santana (UEFS)"
          />
        </div>

        <div class="mt-4 flex flex-1 items-start">
          <p class="max-w-xs text-sm leading-8">
            Universidade Estadual de Feira de Santana
          </p>
        </div>
      </a>
    </section>

    <section class="flex flex-col items-center gap-4 text-center">
      <a
        href="http://www.dchf.uefs.br/"
        target="_blank"
        rel="noopener"
        aria-label="Departamento de Ciências Humanas e Filosofia (DCHF) da UEFS"
        class="flex flex-1 flex-col items-center text-white no-underline transition-opacity hover:opacity-90"
      >
        <div class="flex h-20 items-center justify-center">
          <span class="text-4xl font-extrabold tracking-tight">DCHF</span>
        </div>

        <div class="mt-4 flex flex-1 items-start">
          <p class="max-w-xs text-sm leading-8">
            Departamento de Ciências Humanas e Filosofia
          </p>
        </div>
      </a>
    </section>
  </main>

  <footer
    class="container mx-auto mt-8 border-t border-white/15 px-6 pt-5 text-center"
  >
    <section class="flex flex-col items-center text-center p-6">
      <div class="flex items-center gap-4">
        <a
          href="https://www.instagram.com/uefslabelu/"
          target="_blank"
          rel="noopener"
          aria-label="Instagram do Labelu"
          class="text-white/70 transition-all duration-200 hover:scale-110 hover:text-white"
        >
          <Icon name="mdi:instagram" size={28} />
        </a>
        <a
          href="https://www.youtube.com/@LABELUuefs"
          target="_blank"
          rel="noopener"
          aria-label="Youtube do Labelu"
          class="text-white/70 transition-all duration-200 hover:scale-110 hover:text-white"
        >
          <Icon name="mdi:youtube" size={28} />
        </a>
      </div>
    </section>
    <address
      class="mb-4 flex flex-col items-center gap-2 not-italic text-sm text-white/70"
    >
      <a
        href="mailto:lpbpacheco1@uefs.br"
        class="transition-colors hover:text-white"
      >
        lpbpacheco1@uefs.br
      </a>
      <a
        href="https://maps.app.goo.gl/9qCDBbf8MXFwN5hw9"
        target="_blank"
        rel="noopener"
        class="max-w-2xl transition-colors hover:text-white"
      >
        Prédio de Programa de Pós-Graduação em História (PPGH) - Avenida
        Transnordestina, S/N - Novo Horizonte CEP 44036-900 - Feira de Santana,
        Bahia.
      </a>
    </address>

    <p
      class="mb-2 flex items-center justify-center gap-2 text-sm text-white/50"
    >
      Desenvolvido por

      <a
        href="https://ecompjr.com.br"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center transition-opacity hover:opacity-100"
      >
        <Image
          src={logoEcompjr}
          alt="Logo EcompJR"
          width={100}
          height={100}
          class="rounded-sm opacity-50"
        />
      </a>
    </p>

    <p class="text-xs text-white/50">
      &copy; {year} {COPYRIGHT_NAME}. Todos os direitos reservados.
    </p>
  </footer>
</footer>
