---
import "../styles/global.css";
import {
  CONTACT_EMAIL,
  LOCATION,
  SITE_DESCRIPTION,
  SITE_TITLE,
} from "../consts";
import { Font } from "astro:assets";
interface Props {
  title: string;
  description: string;
  image?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const baseURL = import.meta.env.BASE_URL;

const {
  title,
  description,
  image = "/og.webp",
  structuredData = [],
} = Astro.props;
const basePath = baseURL.endsWith("/") ? baseURL : `${baseURL}/`;
const imagePath = image.startsWith("/") ? image.slice(1) : image;
const ogImageURL = new URL(`${basePath}${imagePath}`, Astro.site).toString();
const siteURL = new URL(basePath, Astro.site).toString();
const logoURL = new URL(
  `${basePath}assets/logo-labelu.png`,
  Astro.site,
).toString();
const organizationStructuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteURL}#organization`,
  name: "Labelu",
  legalName: "Laboratório de História e Memória da Luta de Classes",
  url: siteURL,
  logo: {
    "@type": "ImageObject",
    url: logoURL,
  },
  image: ogImageURL,
  description: SITE_DESCRIPTION,
  email: CONTACT_EMAIL,
  sameAs: [
    "https://www.instagram.com/uefslabelu/",
    "https://www.youtube.com/@LABELUuefs",
  ],
  address: {
    "@type": "PostalAddress",
    streetAddress:
      "Prédio do Programa de Pós-graduação em História, Anexo do Módulo 7 - UEFS. Av. Transnordestina, s/n",
    addressLocality: "Feira de Santana",
    addressRegion: "BA",
    postalCode: "44036-900",
    addressCountry: "BR",
  },
  location: LOCATION,
};
const extraStructuredData = Array.isArray(structuredData)
  ? structuredData
  : [structuredData];
const jsonLd =
  extraStructuredData.length > 0
    ? {
        "@context": "https://schema.org",
        "@graph": [organizationStructuredData, ...extraStructuredData],
      }
    : organizationStructuredData;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />

<!-- Sitemap & RSS -->
<link rel="sitemap" href={new URL("sitemap-index.xml", Astro.site)} />
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={new URL("rss.xml", Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Favicons -->
<link rel="icon" href={`${baseURL}/favicon.ico`} />
<link
  rel="apple-touch-icon"
  sizes="180x180"
  href={`${baseURL}/apple-touch-icon.png`}
/>
<link
  rel="icon"
  type="image/png"
  sizes="32x32"
  href={`${baseURL}/favicon-32x32.png`}
/>
<link
  rel="icon"
  type="image/png"
  sizes="16x16"
  href={`${baseURL}/favicon-16x16.png`}
/>
<link rel="manifest" href={`${baseURL}/site.webmanifest`} />
<meta name="msapplication-TileColor" content="#7d2418" />
<meta name="msapplication-config" content={`${baseURL}/browserconfig.xml`} />
<meta name="theme-color" content="#7d2418" />

<!-- Fonts -->
<Font cssVariable="--font-body" preload />
<Font cssVariable="--font-heading" preload />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:site_name" content="Labelu" />
<meta property="og:locale" content="pt_BR" />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />
<meta property="twitter:url" content={canonicalURL} />

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<script is:inline>
  if ("serviceWorker" in navigator) {
    navigator.serviceWorker.register("/pj-labelu/sw.js", {
      scope: "/pj-labelu/",
    });
  }
</script>
