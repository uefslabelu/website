---
import { Image } from "astro:assets";
import HeaderLink from "./HeaderLink.astro";
import logoLabelu from "../assets/logos/labelu-logo.svg";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<header class="bg-page border-b border-accent-600 sticky top-0 z-50">
  <nav class="flex items-center justify-between max-w-6xl mx-auto py-2 px-6">
    <a
      href={baseUrl}
      class="flex items-center shrink-0 no-underline"
    >
      <Image
        src={logoLabelu}
        alt="Logo Labelu"
        width={100}
        height={60}
        sizes="100px"
        class="h-auto"
      />
    </a>

    <div
      id="nav-links"
      class="hidden bg-page sm:flex sm:flex-row items-center gap-0.5
        max-sm:absolute max-sm:top-full max-sm:left-0 max-sm:right-0
        max-sm:border-b max-sm:border-accent-600
        max-sm:py-2 max-sm:shadow-sm
        [&_a]:text-accent-800 [&_a]:no-underline [&_a]:font-medium
        [&_a]:rounded [&_a]:px-3 [&_a]:py-1.5 [&_a]:text-sm
        [&_a]:transition-colors [&_a]:duration-150
        max-sm:[&_a]:w-full max-sm:[&_a]:rounded-none max-sm:[&_a]:px-6 max-sm:[&_a]:py-3 max-sm:[&_a]:text-base"
    >
      <HeaderLink href="/">Início</HeaderLink>
      <HeaderLink href="/pesquisas">Pesquisas</HeaderLink>
      <HeaderLink href="/produções">Produções</HeaderLink>
      <HeaderLink href="/agenda">Agenda</HeaderLink>
      <HeaderLink href="/equipe">Equipe</HeaderLink>
      <HeaderLink href="/acervos">Acervos</HeaderLink>
      <HeaderLink href="/sobre">Sobre</HeaderLink>
    </div>

    <button
      id="menu-toggle"
      class="sm:hidden flex flex-col justify-center gap-1.5 bg-transparent border-none cursor-pointer p-2"
      aria-label="Abrir menu"
      aria-expanded="false"
    >
      <span
        id="line-1"
        class="block w-6 h-0.5 bg-accent-800 rounded origin-center transition-all duration-300"
      ></span>
      <span
        id="line-2"
        class="block w-6 h-0.5 bg-accent-800 rounded transition-all duration-300"
      ></span>
      <span
        id="line-3"
        class="block w-6 h-0.5 bg-accent-800 rounded origin-center transition-all duration-300"
      ></span>
    </button>
  </nav>
</header>

<script>
  function initMenu() {
    const toggle = document.getElementById("menu-toggle");
    const navLinks = document.getElementById("nav-links");
    const line1 = document.getElementById("line-1");
    const line2 = document.getElementById("line-2");
    const line3 = document.getElementById("line-3");

    if (!toggle || !navLinks) return;

    function openMenu() {
      navLinks?.classList.remove("hidden");
      toggle?.setAttribute("aria-expanded", "true");
      toggle?.setAttribute("aria-label", "Fechar menu");
      line1?.classList.add("rotate-45", "translate-y-[7px]");
      line2?.classList.add("opacity-0");
      line3?.classList.add("-rotate-45", "-translate-y-[7px]");
    }

    function closeMenu() {
      navLinks?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
      toggle?.setAttribute("aria-label", "Abrir menu");
      line1?.classList.remove("rotate-45", "translate-y-[7px]");
      line2?.classList.remove("opacity-0");
      line3?.classList.remove("-rotate-45", "-translate-y-[7px]");
    }

    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      toggle.getAttribute("aria-expanded") === "false"
        ? openMenu()
        : closeMenu();
    });

    document.addEventListener("click", (e) => {
      if (
        !toggle.contains(e.target as Node) &&
        !navLinks.contains(e.target as Node)
      ) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMenu();
    });
  }

  initMenu();

  // Handle View Transitions
  document.addEventListener("astro:after-swap", initMenu);
</script>
