---
import { Image } from "astro:assets";
import bgImage from "../assets/site-images/bg-strike.jpeg";
import logoImage from "../assets/logos/labelu-logo-alt.svg";
---

<section class="relative w-full overflow-hidden">
  {/* Background Image */}
  <div class="absolute inset-0 z-0">
    <Image
      src={bgImage}
      alt="Fundo página inicial"
      class="w-full h-full object-cover object-center"
      quality="high"
    />
    <div class="absolute inset-0 bg-black/60"></div>
  </div>

  {/* Content */}
  <div
    class="relative z-10 px-6 py-6 md:py-16 lg:py-20 mb-6 sm:mb-8 md:mb-10 lg:mb-12"
  >
    <div
      class="mx-auto max-w-6xl flex flex-col md:flex-row items-center md:items-center gap-6 md:gap-10 lg:gap-16"
    >
      <div class="shrink-0 w-1/2 md:w-2/5">
        <Image
          src={logoImage}
          alt="Logo Labelu"
          class="w-full h-auto drop-shadow-lg"
        />
      </div>
      <div class="flex-1 text-center md:text-left text-white">
        <h1
          class="font-heading text-2xl md:text-3xl lg:text-4xl font-bold text-white leading-tight drop-shadow-md"
        >
          Laboratório de História e Memória da Luta de Classes
        </h1>
      </div>
    </div>
  </div>
</section>
