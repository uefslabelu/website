---
import { getCollection } from "astro:content";
import TimelineEvent from "./TimelineEvent.astro";

const schedule = await getCollection("schedule");

// Sort events by date (ascending for future events so the closest is first)
const sortedEvents = schedule.sort(
  (a, b) => a.data.date.valueOf() - b.data.date.valueOf(),
);

// Filter future events
const now = new Date().valueOf();
let displayEvents = sortedEvents.filter(
  (event) => event.data.date.valueOf() >= now,
);

// If there are no future events, just show the most recent past ones
if (displayEvents.length === 0) {
  displayEvents = schedule
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 3);
} else {
  displayEvents = displayEvents.slice(0, 3);
}

const baseUrl = import.meta.env.BASE_URL;
---

<section class="w-full mx-auto py-12 px-6">
  <div class="flex flex-wrap items-center justify-between gap-2 mb-8 md:mb-10">
    <h2 class="text-2xl sm:text-4xl font-bold text-accent-800 font-heading">
      Próximos Eventos na Agenda
    </h2>
    <a
      href={`${baseUrl}/agenda`}
      class="shrink-0 text-xs sm:text-sm font-semibold text-accent-600 hover:text-accent-800 uppercase tracking-wider flex items-center gap-1"
    >
      VER MAIS <span aria-hidden="true">&rarr;</span>
    </a>
  </div>

  <ol class="timeline list-none p-0 relative">
    {displayEvents.map((event) => <TimelineEvent event={event} />)}
  </ol>
</section>

<style>
  .timeline {
    padding-left: 0;
  }
</style>
