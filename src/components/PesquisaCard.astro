---
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";

interface Props {
  pesquisa: CollectionEntry<"research">;
}

const { pesquisa } = Astro.props;
const { title, line, startYear, endYear, summary, publication, researchers } =
  pesquisa.data;

const currentYear = new Date().getFullYear();

// Determine if we have dates and status
const hasStartYear = startYear !== null && startYear !== undefined;
const hasEndYear = endYear !== null && endYear !== undefined;
const hasBothYears = hasStartYear && hasEndYear;
const isOngoing = hasBothYears ? endYear >= currentYear : hasStartYear;

const baseUrl = import.meta.env.BASE_URL;
const pesquisaUrl = `${baseUrl}/pesquisas/${pesquisa.id}/`;

// Resolve research line to get full title
const researchLineEntry = await getEntry("researchLine", line);
const researchLineTitle = researchLineEntry?.data.title || line;

// Format date display
let dateDisplay = "";
if (hasStartYear) {
  if (hasEndYear) {
    dateDisplay = `${startYear} – ${endYear}`;
  } else {
    dateDisplay = `${startYear} – atual`;
  }
}

// Resolve researcher IDs to full team member data
const resolvedResearchers = (
  await Promise.all(researchers?.map((id) => getEntry("team", id)) || [])
).filter(Boolean);
---

<article
  class="group relative bg-surface rounded-xl px-6 py-5 shadow-sm
        hover:-translate-y-0.5 hover:shadow-md transition-all duration-200"
>
  <header
    class="flex justify-between items-start gap-4 mb-2
          max-[720px]:flex-col-reverse max-[720px]:items-start"
  >
    <div class="flex flex-col gap-1.5">
      {
        dateDisplay && (
          <span class="text-sm text-secondary-text font-bold">
            {dateDisplay}
          </span>
        )
      }
      {
        hasStartYear &&
          (isOngoing ? (
            <span class="text-xs uppercase tracking-wide px-2.5 py-0.5 rounded-full font-semibold whitespace-nowrap bg-accent-500 text-white">
              Em andamento
            </span>
          ) : (
            <span class="text-xs uppercase tracking-wide px-2.5 py-0.5 rounded-full font-semibold whitespace-nowrap bg-accent-800 text-white">
              Finalizada
            </span>
          ))
      }
    </div>

    <span
      class="text-xs uppercase tracking-wide px-2.5 py-0.5 rounded-full
        font-semibold bg-raised text-body shrink-0 max-w-xs truncate"
    >
      {researchLineTitle}
    </span>
  </header>

  <h2 class="text-xl font-semibold mt-1 mb-2">
    <a
      href={pesquisaUrl}
      class="text-title no-underline hover:text-accent-500 transition-colors duration-150"
    >
      {title}
    </a>
  </h2>

  <p class="text-sm text-secondary-text mb-3 leading-relaxed line-clamp-3">
    {summary}
  </p>

  {/* Pesquisadores */}
  {
    resolvedResearchers.length > 0 && (
      <div class="flex items-center gap-1.5 text-sm text-secondary-text mb-3 flex-wrap">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="shrink-0 opacity-60"
          aria-hidden="true"
        >
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </svg>
        {resolvedResearchers.map((r, i) => (
          <>
            <a
              href={`${baseUrl}/equipe/${r?.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent-600 no-underline hover:underline font-medium"
              title={`Currículo Lattes de ${r?.data.fullname}`}
            >
              {r?.data.fullname}
            </a>
            {i < resolvedResearchers.length - 1 && (
              <span class="text-border" aria-hidden="true">
                ·
              </span>
            )}
          </>
        ))}
      </div>
    )
  }

  <div class="flex items-center gap-4">
    <a
      href={pesquisaUrl}
      class="text-sm text-accent-600 font-semibold no-underline hover:underline inline-block"
    >
      Ver detalhes →
    </a>

    {
      publication && (
        <a
          href={publication}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-secondary-text font-semibold no-underline
                hover:text-accent-600 hover:underline inline-block"
        >
          Ver publicação ↗
        </a>
      )
    }
  </div>
</article>

